# Copy these into `.env.local` (project root) for the YouTube Playlist Length tool.
# Get a key: https://console.cloud.google.com/apis/credentials
# Enable "YouTube Data API v3" for the project.

YOUTUBE_API_KEY=

# Optional: Plausible analytics on `/youtube-playlist-length` only (layout script).
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=yourdomain.com
