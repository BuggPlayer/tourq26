// TorqStudio Interview Hub — Prisma schema
// Demo: SQLite (`file:./dev.db`). Production: set provider to "postgresql" and DATABASE_URL to Postgres.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum QuestionType {
  DSA
  UI
  QUIZ
  FRONTEND_SYSTEM_DESIGN
}

model User {
  id                     String    @id @default(cuid())
  name                   String?
  email                  String?   @unique
  emailVerified          DateTime?
  image                  String?
  passwordHash           String?
  role                   String    @default("candidate") // candidate | company | admin
  subscriptionTier       String    @default("free") // free | premium | student
  monthlyQuestionViews   Int       @default(0)
  monthResetAt           DateTime?
  studentVerified        Boolean   @default(false)
  solvedCount            Int       @default(0)
  totalScoreSum          Float     @default(0)
  scoreSamples           Int       @default(0)
  streakDays             Int       @default(0)
  lastActiveDate         DateTime?
  accounts               Account[]
  sessions               Session[]
  progress               UserProgress[]
  planEnrollments        UserPlanEnrollment[]
  talentPool             TalentPoolEntry?
  mockBookings           MockInterviewBooking[]
  forumPosts             ForumPost[]
  jobPostings            JobPosting[] @relation("PostedJobs")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model CompanyTag {
  id        String     @id @default(cuid())
  name      String     @unique
  category  String // FAANG | unicorn | service | other
  questions Question[] @relation("QuestionCompanyTags")
}

model Question {
  id               String         @id @default(cuid())
  type             QuestionType
  title            String
  description      String
  difficulty       String // easy | medium | hard
  topic            String
  framework        String? // vanilla | react | vue | angular | svelte
  defaultLanguage  String? // for DSA
  starterCode      String? // JSON string: { "javascript": "...", ... }
  tests            String? // JSON: test cases or quiz/UI checks
  officialSolution String?
  systemDesignMeta String? // JSON: nodes/edges for official FSD solution
  createdAt        DateTime       @default(now())
  companyTags      CompanyTag[]   @relation("QuestionCompanyTags")
  progress         UserProgress[]
  forumThreads     ForumThread[]
}

model UserProgress {
  id          String   @id @default(cuid())
  userId      String
  questionId  String
  solved      Boolean  @default(false)
  score       Float?
  attempts    Int      @default(0)
  lastCode    String?
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
}

model PreparationPlan {
  id           String               @id @default(cuid())
  slug         String               @unique
  name         String
  description  String
  durationDays Int
  milestones   String // JSON array of { id, title, questionCount }
  sortOrder    Int                  @default(0)
  enrollments  UserPlanEnrollment[]
}

model UserPlanEnrollment {
  id               String          @id @default(cuid())
  userId           String
  planId           String
  startedAt        DateTime        @default(now())
  milestonesDone   Int             @default(0)
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan             PreparationPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([userId, planId])
}

model JobPosting {
  id          String   @id @default(cuid())
  companyName String
  title       String
  description String
  location    String
  skills      String // JSON string array
  postedById  String?
  createdAt   DateTime @default(now())
  postedBy    User?    @relation("PostedJobs", fields: [postedById], references: [id])
}

model TalentPoolEntry {
  id         String   @id @default(cuid())
  userId     String   @unique
  optIn      Boolean  @default(false)
  avgScore   Float    @default(0)
  percentile Float?
  skills     String // JSON array
  location   String?
  headline   String?
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MockInterviewBooking {
  id              String    @id @default(cuid())
  userId          String
  stripeSessionId String?
  scheduledAt     DateTime?
  calendlyEventUrl String?
  status          String    @default("pending") // pending | paid | scheduled | completed
  amountInr       Int       @default(2499)
  createdAt       DateTime  @default(now())
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ForumThread {
  id         String      @id @default(cuid())
  questionId String
  title      String
  question   Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  posts      ForumPost[]
  createdAt  DateTime    @default(now())
}

model ForumPost {
  id        String      @id @default(cuid())
  threadId  String
  userId    String
  body      String
  createdAt DateTime    @default(now())
  thread    ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}
